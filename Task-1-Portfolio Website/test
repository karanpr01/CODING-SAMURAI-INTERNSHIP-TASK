import { useForm, ValidationError } from "@formspree/react"
import { Input } from "./ui/input"
import { Textarea } from "./ui/textarea"
import { Button } from "./ui/button"

const Contact = () => {
  const [state, handleSubmit] = useForm("mqalrpvj") // replace with your form ID

  if (state.succeeded) {
    return (
      <section className="py-20 text-center">
        <h2 className="text-3xl font-bold mb-4">Thanks for your message 🎉</h2>
        <p className="text-muted-foreground">I’ll get back to you soon.</p>
      </section>
    )
  }

  return (
    <section id="contact" className="py-20 container">
      <h2 className="text-3xl font-bold text-center mb-6">Contact Me</h2>
      <form onSubmit={handleSubmit} className="max-w-lg mx-auto space-y-4">
        {/* Email */}
        <div>
          <Input id="email" type="email" name="email" placeholder="Your Email" required />
          <ValidationError prefix="Email" field="email" errors={state.errors} />
        </div>

        {/* Message */}
        <div>
          <Textarea id="message" name="message" placeholder="Your Message" rows={4} required />
          <ValidationError prefix="Message" field="message" errors={state.errors} />
        </div>

        {/* Submit */}
        <Button type="submit" disabled={state.submitting} className="w-full">
          {state.submitting ? "Sending..." : "Send Message"}
        </Button>
      </form>
    </section>
  )
}

export default Contact
